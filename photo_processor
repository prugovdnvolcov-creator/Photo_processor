log = None

class NameGenerator:
    @staticmethod
    def extract_article(text):
        """Логика V97: поиск цифр в любом месте строки"""
        match_long = re.search(r'(\d{4,10})', text)
        if match_long: return match_long.group(1)
        match_any = re.search(r'(\d+)', text)
        if match_any: return match_any.group(1)
        clean = re.sub(r'[^\w\-]', '_', text)
        return clean if clean else "unknown"

class Brain:
    def __init__(self):
        self.model = None; self.processor = None
        self.knowledge_base = {"PLATE": [], "PRODUCT": [], "LIFESTYLE": []}
        if AI_AVAILABLE:
            try:
                self.model = CLIPModel.from_pretrained("openai/clip-vit-base-patch32")
                self.processor = CLIPProcessor.from_pretrained("openai/clip-vit-base-patch32")
                self.load_knowledge_base()
            except Exception as e: log.error(f"AI Brain Error: {e}")

    def _safe_normalize(self, embed):
        if not isinstance(embed, torch.Tensor):
            if hasattr(embed, 'image_embeds'): embed = embed.image_embeds
            elif hasattr(embed, 'pooler_output'): embed = embed.pooler_output
            else:
                try: embed = torch.tensor(embed)
                except: return None
        return F.normalize(embed, p=2, dim=-1)

    def load_knowledge_base(self):
        if not os.path.exists(Config.KNOWLEDGE_BASE_DIR):
            for k in self.knowledge_base: os.makedirs(os.path.join(Config.KNOWLEDGE_BASE_DIR, k), exist_ok=True)
            return
        c = 0
        for label in self.knowledge_base:
            folder = os.path.join(Config.KNOWLEDGE_BASE_DIR, label)
            if not os.path.exists(folder): continue
            for fname in os.listdir(folder):
                if fname.lower().endswith(('jpg','png','jpeg','webp')):
                    try:
                        img = Image.open(os.path.join(folder, fname)).convert("RGB")
                        inputs = self.processor(images=img, return_tensors="pt")
                        with torch.no_grad(): raw = self.model.get_image_features(**inputs)
                        embed = self._safe_normalize(raw)
                        if embed is not None: self.knowledge_base[label].append(embed); c+=1
                    except: pass
        log.info(f"Knowledge Base: {c} cases ready.")

    def predict_context_strip(self, strip_pil):
        if self.model is None: return 0.5
        labels = ["solid empty studio background", "textured interior lifestyle surface"]
        inputs = self.processor(text=labels, images=strip_pil, return_tensors="pt", padding=True)
        with torch.no_grad():
            probs = self.model(**inputs).logits_per_image.softmax(dim=1).numpy()[0]
        return probs[0]

    def predict_full(self, image_pil):
        if self.model is None: return "PRODUCT", 0.0, "NO_AI"
        inputs = self.processor(images=image_pil, return_tensors="pt")
        with torch.no_grad(): raw = self.model.get_image_features(**inputs)
        img_embed = self._safe_normalize(raw)
        
        best_sim = -1.0; best_lbl = None
        for lbl, embeds in self.knowledge_base.items():
            for ref in embeds:
                sim = torch.mm(img_embed, ref.T).item()
                if sim > best_sim: best_sim = sim; best_lbl = lbl
        if best_sim > Config.SIMILARITY_THRESHOLD: return best_lbl, best_sim, "KB_MATCH"

        labels = ["PRODUCT", "PLATE", "LIFESTYLE"]
        prompts = ["a packaged commercial product", "a food plate top view", "lifestyle food interior decorations"]
        inputs = self.processor(text=prompts, images=image_pil, return_tensors="pt", padding=True)
        with torch.no_grad():
            probs = self.model(**inputs).logits_per_image.softmax(dim=1).numpy()[0]
        idx = np.argmax(probs)
        return labels[idx], float(probs[idx]), "ZERO_SHOT"

class DownloadManager:
    @staticmethod
    def download_and_extract(url, dest):
        os.makedirs(dest, exist_ok=True)
        archive_path = os.path.join(dest, "archive.zip")
        try:
            dl_url = url
            headers = {'User-Agent': 'Mozilla/5.0'}
            if "disk.yandex" in url or "yadi.sk" in url:
                api = 'https://cloud-api.yandex.net/v1/disk/public/resources/download?' + urlencode({'public_key': url})
                r = requests.get(api, headers=headers)
                if r.status_code == 200: dl_url = r.json().get('href')
            elif "drive.google.com" in url:
                gdown.download(url, output=archive_path, quiet=False, fuzzy=True)
                dl_url = None
            if dl_url:
                with requests.get(dl_url, stream=True, headers=headers) as r:
                    r.raise_for_status()
                    with open(archive_path, 'wb') as f: shutil.copyfileobj(r.raw, f)
            
            with zipfile.ZipFile(archive_path, 'r') as zf:
                for member in zf.infolist():
                    try: member.filename = member.filename.encode('cp437').decode('cp866')
                    except: pass
                    safe_name = member.filename.replace('\t', ' ').replace('\n', '').replace('\r', '')
                    safe_name = re.sub(r'[<>:"/\\|?*]', '_', safe_name).strip()
                    if "__MACOSX" in safe_name: continue
                    target = os.path.join(dest, safe_name)
                    if member.is_dir(): os.makedirs(target, exist_ok=True)
                    else:
                        os.makedirs(os.path.dirname(target), exist_ok=True)
                        with zf.open(member) as s, open(target, 'wb') as t: shutil.copyfileobj(s, t)
            return True
        except Exception as e:
            log.error(f"DL error: {e}"); return False

