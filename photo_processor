class GeometryExpert:
    @staticmethod
    def get_bboxes(pil_orig, pil_mask, model_type):
        W, H = pil_orig.size
        mask_arr = np.array(pil_mask.convert("L"))
        
        # Эрозия для удаления "шумных" пикселей маски
        kernel = np.ones((5,5), np.uint8)
        mask_clean = cv2.erode(mask_arr, kernel, iterations=1)
        
        cnts, _ = cv2.findContours(mask_clean, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        core_bbox = (0,0,W,H); solidity = 0.0; circularity = 0.0
        
        if cnts:
            c = max(cnts, key=cv2.contourArea)
            area = cv2.contourArea(c)
            hull = cv2.convexHull(c)
            solidity = area / cv2.contourArea(hull) if cv2.contourArea(hull) > 0 else 0
            peri = cv2.arcLength(c, True)
            circularity = (4 * math.pi * area) / (peri * peri) if peri > 0 else 0
            x,y,w,h = cv2.boundingRect(c); core_bbox = (x,y,x+w,y+h)
        
        # Если это тарелка - запускаем ГЕОМЕТРИЧЕСКУЮ РЕКОНСТРУКЦИЮ
        if model_type == 'PLATE':
            full_bbox = GeometryExpert._reconstruct_ellipse(pil_orig, core_bbox)
        else:
            full_bbox = core_bbox # Для продуктов берем маску
            
        return core_bbox, full_bbox, solidity, circularity

    @staticmethod
    def _reconstruct_ellipse(pil_orig, core_bbox):
        """
        Ищет дуги тарелки и достраивает из них идеальный эллипс.
        Убирает зависимость от 'белого на белом'.
        """
        W, H = pil_orig.size
        cv_img = cv2.cvtColor(np.array(pil_orig), cv2.COLOR_RGB2BGR)
        gray = cv2.cvtColor(cv_img, cv2.COLOR_BGR2GRAY)
        
        # 1. Усиление локальных теней (края тарелки всегда чуть темнее фона)
        clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
        cl_gray = clahe.apply(gray)
        
        # 2. Поиск краев (Canny)
        edges = cv2.Canny(cl_gray, Config.PLATE_RIM_SENSITIVITY, Config.PLATE_RIM_SENSITIVITY*3)
        
        # 3. Фильтрация точек: берем только те, что вокруг еды
        points = np.column_stack(np.where(edges > 0))
        if len(points) < 20: return core_bbox
        
        cx_food, cy_food = (core_bbox[0]+core_bbox[2])/2, (core_bbox[1]+core_bbox[3])/2
        radius_est = max(core_bbox[2]-core_bbox[0], core_bbox[3]-core_bbox[1]) / 2
        
        valid_points = []
        for p in points:
            dist = math.hypot(p[1]-cx_food, p[0]-cy_food)
            # Берем точки в радиусе от 0.8 до 1.5 от размера еды
            if radius_est * 0.8 < dist < radius_est * 1.8:
                valid_points.append((p[1], p[0])) # OpenCV format (x, y)
        
        if len(valid_points) < 15: 
            # Если не нашли дуги, просто расширяем маску еды на 18% как сейф-зону
            x1,y1,x2,y2 = core_bbox
            pw, ph = (x2-x1)*0.18, (y2-y1)*0.18
            return (max(0,int(x1-pw)), max(0,int(y1-ph)), min(W,int(x2+pw)), min(H,int(y2+ph)))

        # 4. Fit Ellipse (Математическое достроение овала по точкам)
        try:
            ellipse = cv2.fitEllipse(np.array(valid_points, dtype=np.float32))
            (ex, ey), (ew, eh), angle = ellipse
            
            # Проверка адекватности эллипса
            if ew > W or eh > H or ew < (core_bbox[2]-core_bbox[0]):
                 raise ValueError("Ellipse too big/small")
            
            nx1 = max(0, int(ex - ew/2))
            ny1 = max(0, int(ey - eh/2))
            nx2 = min(W, int(ex + ew/2))
            ny2 = min(H, int(ey + eh/2))
            return (nx1, ny1, nx2, ny2)
        except:
            # Fallback к расширению
            x1,y1,x2,y2 = core_bbox
            pw, ph = (x2-x1)*0.18, (y2-y1)*0.18
            return (max(0,int(x1-pw)), max(0,int(y1-ph)), min(W,int(x2+pw)), min(H,int(y2+ph)))

class ProcessorV107:
    def __init__(self):
        self.session = new_session("isnet-general-use")
        self.brain = Brain()

    def process(self, image_path):
        filename = os.path.basename(image_path)
        log.info(f"--- Analyzing: {filename} ---")
        try:
            orig = Image.open(image_path).convert("RGBA")
            orig = ImageOps.exif_transpose(orig)
            orig_rgb = orig.convert("RGB")
            W, H = orig.size
            
            # Анализ фона по краям
            sw = int(W * Config.STRIP_WIDTH_RATIO)
            strip_l = orig_rgb.crop((0, 0, sw, H))
            strip_r = orig_rgb.crop((W - sw, 0, W, H))
            
            cv_l = cv2.cvtColor(np.array(strip_l), cv2.COLOR_RGB2GRAY)
            cv_r = cv2.cvtColor(np.array(strip_r), cv2.COLOR_RGB2GRAY)
            lap_var = np.mean([cv2.Laplacian(cv_l, cv2.CV_64F).var(), cv2.Laplacian(cv_r, cv2.CV_64F).var()])
            
            ai_lbl, ai_conf, ai_src = self.brain.predict_full(orig_rgb)
            try: mask_img = remove(orig, session=self.session, only_mask=True)
            except: mask_img = Image.new("L", (W,H), 0)

            # --- DECISION ---
            model_type = ai_lbl
            if ai_src != "KB_MATCH":
                if lap_var > Config.BG_LAPLACIAN_THRESHOLD: 
                    model_type = "LIFESTYLE"
                elif ai_lbl == "PLATE":
                    _, _, sol, circ = GeometryExpert.get_bboxes(orig_rgb, mask_img, 'PLATE')
                    if sol < Config.PLATE_SOLIDITY_MIN or circ < Config.PLATE_CIRCULARITY_MIN:
                        model_type = "PRODUCT"
                elif ai_conf < Config.AI_CONFIDENCE_THRESHOLD:
                    model_type = "PRODUCT"

            c_bbox, f_bbox, sol, circ = GeometryExpert.get_bboxes(orig_rgb, mask_img, model_type)
            
            # Форма
            x1,y1,x2,y2 = c_bbox
            ar = (x2-x1)/max(1, (y2-y1))
            shape = "DEFAULT"
            if ar < Config.NORMAL_ASPECT_THRESHOLD: shape = "THIN_VERT" if ar < 0.5 else "THICK_VERT"
            elif ar > Config.LONG_ASPECT_THRESHOLD: shape = "LONG_HORIZ"
            else: shape = "NORMAL_HORIZ"
            
            log.info(f"  > Decision: {model_type} | Shape: {shape} | Lap: {lap_var:.1f}")

            # --- SCALING & CENTERING ---
            cw, ch = Config.CANVAS_W, Config.CANVAS_H
            target_bbox = f_bbox if model_type == 'PLATE' else c_bbox
            margins = Config.MARGINS_PLATE if model_type == 'PLATE' else \
                      (Config.MARGINS_PRODUCT.get(shape, Config.MARGINS_PRODUCT["DEFAULT"]) if model_type == 'PRODUCT' else Config.MARGINS_LIFESTYLE)

            tx1, ty1, tx2, ty2 = target_bbox
            tw, th = max(1, tx2-tx1), max(1, ty2-ty1)
            
            if model_type == 'LIFESTYLE':
                scale = max(cw/W, ch/H) * 1.3
            else:
                scale = min((cw - margins['side']*2)/tw, (ch - (margins['top']+margins['bottom']))/th)
                if model_type == 'PLATE': scale *= 0.98

            fw, fh = int(W*scale), int(H*scale)
            resized = orig_rgb.resize((fw, fh), Image.LANCZOS)
            
            # ПРЕЦИЗИОННОЕ ЦЕНТРИРОВАНИЕ (EQUALIZER MATH)
            pad_x = (cw - (tw * scale)) / 2
            pad_y = (ch - (th * scale)) / 2
            shift_x = int(pad_x - (tx1 * scale))
            shift_y = int(pad_y - (ty1 * scale))

            if model_type == 'LIFESTYLE':
                shift_x = max(min(0, shift_x), cw - fw); shift_y = max(min(0, shift_y), ch - fh)

            if model_type == 'LIFESTYLE':
                canvas = resized.resize((cw, ch), Image.BICUBIC).filter(ImageFilter.GaussianBlur(100))
            else:
                canvas = Image.new("RGB", (cw, ch), Config.PRODUCT_BG_COLOR)
            
            canvas.paste(resized, (shift_x, shift_y))
            canvas = ImageEnhance.Sharpness(canvas).enhance(Config.FINAL_SHARPNESS)
            canvas = ImageEnhance.Contrast(canvas).enhance(Config.FINAL_CONTRAST)
            
            del resized, orig, orig_rgb, mask_img
            gc.collect()
            return canvas, model_type
        except Exception as e:
            log.error(f"Error {filename}: {e}", exc_info=True); return None, None

def main():
    global log
    log = setup_logging()
    print("\n=== AI PHOTO AGENT V107 (ELLIPSE) ===")
    print("Paste links (one per line, empty line to start):")
    links = []
    while True:
        l = input("Link: ").strip()
        if not l: break
        links.append(l)
    
    if not links: return
    processor = ProcessorV107()
    os.makedirs(Config.OUTPUT_DIR, exist_ok=True)
    
    for url in links:
        if os.path.exists(Config.DOWNLOAD_DIR): shutil.rmtree(Config.DOWNLOAD_DIR)
        DownloadManager.download_and_extract(url, Config.DOWNLOAD_DIR)
        
        batches = {}
        for r, d, f in os.walk(Config.DOWNLOAD_DIR):
            img_files = [file for file in f if file.lower().endswith(('.jpg','.png','.jpeg','.webp'))]
            if not img_files: continue
            folder_name = os.path.basename(r)
            for img in img_files:
                # Naming Logic V97
                if r != Config.DOWNLOAD_DIR and re.search(r'\d', folder_name):
                    art = NameGenerator.extract_article(folder_name)
                else:
                    art = NameGenerator.extract_article(img)
                if art not in batches: batches[art] = []
                batches[art].append(os.path.join(r, img))
        
        for art, paths in batches.items():
            log.info(f"--- Processing Batch: {art} ---")
            results = []
            for p in paths:
                res, mtype = processor.process(p)
                if res: results.append({'img': res, 'type': mtype})
            
            type_order = {'PLATE': '_1', 'PRODUCT': '_2', 'LIFESTYLE': '_3'}
            for item in results: item['pref'] = type_order.get(item['type'], '_0')
            sorted_res = sorted(results, key=lambda x: x['pref'])
            counts = {'_1': 0, '_2': 0, '_3': 0}
            for item in sorted_res:
                p = item['pref']
                counts[p] += 1
                suffix = "" if counts[p] == 1 else f"({counts[p]-1})"
                out_name = f"{art}{p}{suffix}.png"
                item['img'].save(os.path.join(Config.OUTPUT_DIR, out_name))
                log.info(f"  > Saved: {out_name} [{item['type']}]")

    try: shutil.rmtree(Config.DOWNLOAD_DIR)
    except: pass
    input("\nDone. Press Enter to Exit...")

if __name__ == "__main__":
    main()


